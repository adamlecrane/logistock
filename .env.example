# Default uses SQLite for instant local dev. Switch to PostgreSQL by:
# 1. Replacing the provider in prisma/schema.prisma with "postgresql"
# 2. Setting DATABASE_URL to your Postgres connection string
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-please-generate-with-openssl-rand-base64-32"

# Demo seed credentials
SEED_ADMIN_EMAIL="admin@logistock.local"
SEED_ADMIN_PASSWORD="admin123"
